# =====================================================
# KONFIGURASI APLIKASI
# =====================================================

# Nama aplikasi (tampil di title, email, dll)
APP_NAME="Ujian Semester OOP"

# Environment: development, production, testing
APP_ENV=development

# URL aplikasi (tanpa trailing slash)
APP_URL=http://localhost

# Debug mode: true (tampilkan error), false (tampilkan error generic)
APP_DEBUG=true

# Timezone
APP_TIMEZONE=Asia/Jakarta

# =====================================================
# KONFIGURASI DATABASE
# =====================================================

# Database driver: mysql, pgsql, sqlite
DB_DRIVER=mysql

# Host database (localhost untuk local, IP untuk remote)
DB_HOST=localhost
DB_PORT=3306

# Nama database
DB_NAME=ujian_semester

# Username dan password database
DB_USER=root
DB_PASS=

# Charset dan collation
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# =====================================================
# KONFIGURASI SESSION
# =====================================================

# Nama session cookie
SESSION_NAME=ujian_semester_session

# Lifetime session dalam menit (120 = 2 jam)
SESSION_LIFETIME=120

# Path session cookie
SESSION_PATH=/

# Domain session cookie (kosongkan untuk default)
SESSION_DOMAIN=

# Secure cookie (true untuk HTTPS only)
SESSION_SECURE=false

# HttpOnly cookie (true untuk prevent XSS)
SESSION_HTTP_ONLY=true

# =====================================================
# KONFIGURASI KEAMANAN
# =====================================================

# Cost untuk password_hash (default 10, max 12)
HASH_COST=12

# Nama field CSRF token
CSRF_TOKEN_NAME=_token

# CSRF token lifetime dalam menit (0 = tidak expired)
CSRF_TOKEN_LIFETIME=0

# Max login attempts per IP per 15 menit
MAX_LOGIN_ATTEMPTS=5

# Lockout duration dalam menit
LOCKOUT_DURATION=15

# =====================================================
# KONFIGURASI EMAIL (BONUS - untuk forgot password real)
# =====================================================

# Mail driver: smtp, sendmail, log (log untuk simulasi)
MAIL_DRIVER=log

# SMTP Host (jika menggunakan SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls

# From address
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# =====================================================
# KONFIGURASI CACHE (BONUS)
# =====================================================

# Cache driver: file, database, redis
CACHE_DRIVER=file

# Cache lifetime dalam menit
CACHE_LIFETIME=60

# =====================================================
# KONFIGURASI LOGGING (BONUS)
# =====================================================

# Log level: debug, info, warning, error
LOG_LEVEL=debug

# Log file path (relatif dari BASE_PATH)
LOG_FILE=storage/logs/app.log
